generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  source    String   @default("Landing Page Persogelo")
  status    String   @default("Novo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
